generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN_CENTRO
  PROFESIONAL
}

enum ActivityType {
  GESTION
  REUNION
  DERECHO
}

enum Category {
  CAT_A
  CAT_B
  CAT_C
  CAT_D
}

enum SurveyStatus {
  DRAFT
  SUBMITTED
}

enum AbsenceType {
  HOLIDAY
  ADMIN_DAY
  TRAINING
}

model HealthCenter {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  professionals Professional[]
  activities  Activity[]
  surveys     Survey[]
  absences    Absence[]

  @@index([code])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          Role
  healthCenterId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  healthCenter HealthCenter? @relation(fields: [healthCenterId], references: [id])
  professional Professional?

  @@index([email])
  @@index([healthCenterId])
}

model Professional {
  id            String    @id @default(cuid())
  healthCenterId String
  userId        String?   @unique
  name          String
  rut           String
  position      String
  category      Category
  weeklyHours   Float
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  healthCenter HealthCenter @relation(fields: [healthCenterId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
  surveys     Survey[]

  @@index([healthCenterId])
  @@index([userId])
  @@index([rut])
}

model Activity {
  id            String       @id @default(cuid())
  healthCenterId String
  code          String
  type          ActivityType
  name          String
  weeklyHours   Float
  criteria      String?
  appliesTo     String
  isRequired    Boolean      @default(false)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  healthCenter HealthCenter  @relation(fields: [healthCenterId], references: [id])
  surveyEntries SurveyEntry[]

  @@index([healthCenterId])
  @@index([code])
}

model Survey {
  id            String        @id @default(cuid())
  healthCenterId String
  professionalId String
  year          Int
  week          Int
  status        SurveyStatus  @default(DRAFT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  healthCenter HealthCenter  @relation(fields: [healthCenterId], references: [id])
  professional Professional   @relation(fields: [professionalId], references: [id])
  entries     SurveyEntry[]

  @@unique([professionalId, year, week])
  @@index([healthCenterId])
  @@index([professionalId])
}

model SurveyEntry {
  id         String   @id @default(cuid())
  surveyId   String
  activityId String
  hours      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  survey   Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id])

  @@index([surveyId])
  @@index([activityId])
}

model Absence {
  id            String      @id @default(cuid())
  healthCenterId String
  year          Int
  type          AbsenceType
  date          DateTime
  description   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  healthCenter HealthCenter @relation(fields: [healthCenterId], references: [id])

  @@index([healthCenterId])
  @@index([year])
}